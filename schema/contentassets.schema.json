{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$anchor": "contentassets",
  "description": "Tracks asset IDs referenced by content items",
  "$merge": {
    "with": {
      "properties": {
        "_assetIds": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "_adapt": { "editorOnly": true },
          "_backboneForms": { "showInUi": false }
        }
      }
    }
  }
}
